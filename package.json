{
  "name": "chyi-portfolio-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gxm": "npm --prefix subprojects/gxm run dev",
    "build": "npm run build:main && npm run build:gxm && node scripts/copy-gxm-dist.mjs",
    "build:main": "node scripts/generate-static-files.mjs && tsc -b && vite build",
